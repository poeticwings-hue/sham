        CREATE TABLE IF NOT EXISTS books (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            title TEXT NOT NULL,
            filename TEXT NOT NULL,
            path TEXT NOT NULL UNIQUE,
            slide_count INTEGER DEFAULT 0,
            mtime REAL,
            size INTEGER,
            shamela_id TEXT,
            folder TEXT
        );
        CREATE TABLE IF NOT EXISTS slides (
