        }
    } catch (e) {
        console.error('Failed to restore session state:', e);
    }
}

function applyPendingSessionState() {
    if (!window.localStorage) return;

    try {
        var state = JSON.parse(localStorage.getItem(SESSION_STATE_KEY));
        if (!state || !state.lastBookId) return;

        // Wait for books to load
        if (!books.length) {
            setTimeout(applyPendingSessionState, 200);
            return;
        }

        var node = bookTree.querySelector('.tree-node[data-book-id="' + state.lastBookId + '"]');
        if (node) {
            // Expand the node and load its structure
            var toggle = node.querySelector('.tree-toggle');
            if (toggle) {
                toggle.click();
                // After structure loads, restore slide
                setTimeout(function() {
                    if (state.lastSlideNumber) {
                        var heading = bookTree.querySelector('.tree-heading[data-heading-id="' + state.lastActiveHeadingId + '"]');
                        if (heading) {
                            heading.click();
                        } else if (state.lastSlideNumber) {
                            loadBookContent(state.lastBookId, { type: 'slide', value: state.lastSlideNumber });
                            setTimeout(function() {
                                reader.scrollTop = state.lastScrollPosition || 0;
                            }, 500);
                        }
                    }
                }, 500);
            }
        }
    } catch (e) {
        console.error('Failed to apply pending session state:', e);
    }
